{
  "name": "amplify-vite-react-template",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsgo && vite build",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "preview": "vite preview",
    "qa:responsive": "tsx ./scripts/responsive-qa.ts",
    "repair:package-billing": "tsx ./scripts/repair-package-billing.ts",
    "sandbox:start": "npm run sandbox:recover",
    "sandbox:clean": "powershell -ExecutionPolicy Bypass -File ./scripts/sandbox-recover.ps1 -NoStart",
    "sandbox:recover": "powershell -ExecutionPolicy Bypass -File ./scripts/sandbox-recover.ps1"
  },
  "dependencies": {
    "@aws-amplify/ui-react": "^6.15.3",
    "@aws-sdk/client-cognito-identity-provider": "^3.1038.0",
    "@aws-sdk/client-s3": "^3.1041.0",
    "@aws-sdk/client-sesv2": "^3.1041.0",
    "@aws-sdk/client-sns": "^3.1038.0",
    "@aws-sdk/s3-request-presigner": "^3.1041.0",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@fortawesome/fontawesome-free": "^7.2.0",
    "aws-amplify": "^6.16.4",
    "docx": "^9.6.1",
    "jspdf": "^4.2.1",
    "lucide-react": "^1.14.0",
    "qrcode": "^1.5.4",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-icons": "^5.6.0",
    "recharts": "^3.8.1",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@aws-amplify/backend": "^1.22.0",
    "@aws-amplify/backend-cli": "^1.8.2",
    "@types/node": "^25.6.0",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.59.1",
    "@typescript-eslint/parser": "^8.59.1",
    "@typescript/native-preview": "^7.0.0-dev.20260429.1",
    "@vitejs/plugin-react": "^6.0.1",
    "esbuild": "^0.28.0",
    "eslint": "^10.2.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "jsonschema": "1.4.1",
    "playwright": "^1.59.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.10"
  }
}
